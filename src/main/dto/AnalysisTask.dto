export top.phj233.smartdatainsightagent.entity.AnalysisTask
 -> package top.phj233.smartdatainsightagent.entity.dto
import jakarta.validation.constraints.Min
import jakarta.validation.constraints.NotBlank
import jakarta.validation.constraints.Size
import top.phj233.smartdatainsightagent.entity.enums.AnalysisStatus
import top.phj233.smartdatainsightagent.model.AnalysisResult
import top.phj233.smartdatainsightagent.model.AnalysisTaskStageRecord

input AnalysisTaskCreateInput {
    name
    originalQuery
}

input AnalysisTaskRenameInput {
    @NotBlank(message = "name 不能为空")
    @Size(max = 20, message = "name 长度不能超过 20")
    name
}

input AdminFailedAnalysisTaskUpdateInput {
    @Size(max = 20, message = "name 长度不能超过 20")
    name?
    originalQuery?
    generatedSql
    parameters?
    status?
    result
    executionTime
    errorMessage
}

input AnalysisExecuteRequest {
    @NotBlank(message = "query 不能为空")
    query: String
    @Min(value = 1, message = "dataSourceId 必须大于 0")
    dataSourceId: Long?
}

input AnalysisTaskReanalyzeInput {
    query: String?
}

input AnalysisTaskCreateResponse {
    taskId: Long
    status
}

AnalysisTaskSummaryView {
    id
    userId
    name
    originalQuery
    status
    executionTime
    errorMessage
}

AnalysisTaskDetailView {
    id
    userId
    name
    originalQuery
    generatedSql
    parameters
    status
    result
    executionTime
    errorMessage
}
