export top.phj233.smartdatainsightagent.entity.User
 -> package top.phj233.smartdatainsightagent.entity.dto
import org.springframework.validation.annotation.Validated
import jakarta.validation.constraints.Email
import jakarta.validation.constraints.NotBlank
import jakarta.validation.constraints.Size

input UserLoginDTO {
    username
    password
}
input UserLoginByCodeDTO {
    code: String
    @Email(message = "邮箱格式错误")
    email
}
input UserRegisterDTO {
    @Size(min = 6, max = 32, message = "用户名长度必须在6-32之间")
    username
    password
    email
    code: String
}

input UserSendCodeDTO {
    @NotBlank(message = "邮箱不能为空")
    @Email(message = "邮箱格式错误")
    email
}

// API 出参: 当前登录用户信息
input UserMeResponse {
    id
    username
    email
    avatar
    enabled
    roles: List<String>
}

